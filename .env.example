# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional Configuration
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_APP_ENV=development

# Google Cloud Vision API (for ISBN OCR scanner)
VITE_GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Cloud Function base URL (for danacode book scraper)
# Local emulator: http://localhost:5001/your-project-id/europe-west1
# Production: https://europe-west1-your-project-id.cloudfunctions.net
# VITE_CLOUD_FUNCTION_BASE_URL=https://europe-west1-your-project-id.cloudfunctions.net
VITE_CLOUD_FUNCTION_BASE_URL=https://us-central1-your-project-id.cloudfunctions.net
